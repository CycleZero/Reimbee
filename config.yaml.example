# ==========================================
# Reimbee — 企业财务报销助手 配置文件
# ==========================================

# ==========================================
# 应用基础设置
# ==========================================
app:
  dev_mode: true           # 开发模式：true=彩色控制台日志，false=JSON 日志
  enable_db_debug: true     # GORM 调试日志

# ==========================================
# HTTP 服务
# ==========================================
server:
  http:
    host: "0.0.0.0"
    port: 8080
    pprof:
      enable: true
      port: 6060
      host: "0.0.0.0"

# ==========================================
# 日志
# ==========================================
log:
  mode: "dev"               # dev | prod
  level: "debug"            # debug | info | warn | error
  dir: "./data/log"

# ==========================================
# MySQL 数据库
# ==========================================
data:
  db:
    host: "${DB_HOST:-localhost}"
    port: "${DB_PORT:-3306}"
    user: "${DB_USER:-root}"
    password: "${DB_PASSWORD:-}"
    db_name: "${DB_NAME:-reimbee}"

  redis:
    host: "${REDIS_HOST:-localhost}"
    port: "${REDIS_PORT:-6379}"
    password: "${REDIS_PASSWORD:-}"

# ==========================================
# LLM 大模型（OpenAI 兼容 API）
# ==========================================
openai:
  base_url: "${OPENAI_BASE_URL}"     # e.g. https://api.openai.com/v1
  api_key: "${OPENAI_API_KEY}"       # sk-xxx
  model: "${OPENAI_MODEL:-gpt-4o}"   # gpt-4o / doubao-pro-32k / deepseek-chat
  temperature: 0.3
  max_tokens: 4096

# ==========================================
# OCR 票据识别
# ==========================================
ocr:
  driver: "multimodal"               # multimodal | paddle | mock

  # 多模态大模型（推荐）
  multimodal:
    base_url: "${OPENAI_BASE_URL}"   # 共用 OpenAI 兼容 API
    api_key: "${OPENAI_API_KEY}"
    model: "${OPENAI_MODEL:-gpt-4o}" # 需支持 Vision
    timeout: 30s

  # PaddleOCR 微服务（本地部署）
  paddle:
    endpoint: "http://localhost:5001"
    timeout: 30s

# ==========================================
# 文件存储
# ==========================================
storage:
  driver: "local"                    # local | minio

  # 本地磁盘
  local:
    base_dir: "./uploads"
    base_url: "/uploads"

  # MinIO / S3 兼容对象存储
  minio:
    endpoint: "${MINIO_ENDPOINT:-localhost:9000}"
    bucket: "${MINIO_BUCKET:-reimbee}"
    access_key: "${MINIO_ACCESS_KEY:-minioadmin}"
    secret_key: "${MINIO_SECRET_KEY:-minioadmin}"
    use_ssl: false
    base_url: "${MINIO_BASE_URL:-http://localhost:9000}"

# ==========================================
# SMTP 邮件
# ==========================================
smtp:
  host: "${SMTP_HOST:-smtp.qq.com}"
  port: "${SMTP_PORT:-587}"
  user: "${SMTP_USER:-}"
  password: "${SMTP_PASSWORD:-}"
  from: "${SMTP_FROM:-noreply@reimbee.com}"

# ==========================================
# 合规规则（单位：分）
# ==========================================
compliance:
  hotel_daily_max: 30000             # 住宿 ¥300/天
  transport_max: 150000              # 交通 ¥1500/次
  entertainment_per_person: 20000    # 招待 ¥200/人
  office_max: 500000                 # 办公用品 ¥5000/次
  invoice_max_age_days: 90           # 发票有效期 90 天

# ==========================================
# Agent 对话
# ==========================================
agent:
  session_ttl_minutes: 30            # 会话超时（分钟）
  max_history_turns: 20              # 最大对话轮数
  max_phase_turns: 10                # 每 Phase 最大交互轮次（防死循环）
  checkpoint_cleanup_hours: 1        # Checkpoint 孤儿清理（小时）
  llm_max_retries: 3                 # LLM API 最大重试次数
  llm_retry_backoff_seconds: 2       # 重试退避初始间隔（秒），指数增长
  tool_timeout_seconds: 30           # 工具调用超时（秒）
  intent_confidence_threshold: 0.7   # 意图分类置信度阈值，低于此值询问用户

# ==========================================
# JWT 认证
# ==========================================
jwt:
  secret: "${JWT_SECRET:-reimbee-jwt-secret-change-in-production}"
  expire_hours: 24

# ==========================================
# 嵌入模型配置
# ==========================================
embedding:
  driver: "openai"                      # openai | bge-m3 | qwen

  openai:
    model: "text-embedding-3-small"
    dimensions: 512

  bge_m3:
    endpoint: "http://localhost:11434"
    model: "bge-m3"
    timeout: 30s

  qwen:
    mode: "ollama"                      # ollama | dashscope
    ollama_endpoint: "http://localhost:11434"
    ollama_model: "qwen2-embedding"
    dashscope_api_key: "${DASHSCOPE_API_KEY}"
    dashscope_model: "text-embedding-v4"
    dimensions: 1024
    timeout: 30s

# ==========================================
# 向量库配置
# ==========================================
vector_store:
  driver: "inmemory"                    # inmemory | milvus | pgvector | chroma

  milvus:
    endpoint: "localhost:19530"
    collection: "reimbee_policies"
    metric_type: "COSINE"
    timeout: 30s

  pgvector:
    dsn: "${PGVECTOR_DSN}"
    table: "reimbee_policies"

  chroma:
    endpoint: "http://localhost:8000"
    collection: "reimbee_policies"
    timeout: 30s
